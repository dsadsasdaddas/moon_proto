{
  "official": {
    "name": "moonbitlang/protoc-gen-mbt",
    "repository": "https://github.com/moonbitlang/protoc-gen-mbt",
    "observed_commit": "9ac87899cf20ea88e31ba77330958ba389eab5fd",
    "runtime_package": "moonbitlang/protobuf@0.1.3",
    "source_files": [
      "README.md",
      "doc/spec.md"
    ],
    "notes": [
      "README says extensions and custom options are ignored.",
      "doc/spec.md documents scalar, optional, repeated, oneof and map MoonBit mappings."
    ],
    "required_source_snippets": {
      "README.md": [
        "MoonBit protobuf generator",
        "Extensions and custom options are ignored"
      ],
      "doc/spec.md": [
        "double      | Double",
        "`optional` field will generate `Option` type in MoonBit",
        "`repeated` field will generate MoonBit `Array`",
        "oneof` fields are encoded as MoonBit `Enum`",
        "Maps are fully supported and will map to MoonBit `Map`"
      ]
    },
    "required_feature_coverage": [
      "scalar",
      "repeated",
      "optional",
      "map",
      "oneof",
      "enum",
      "import",
      "reserved",
      "float",
      "double",
      "int32",
      "int64",
      "uint32",
      "uint64",
      "fixed32",
      "fixed64",
      "bool",
      "string",
      "bytes"
    ]
  },
  "cases": [
    {
      "name": "simple_user",
      "proto": "examples/simple/user.proto",
      "expected_messages": [
        "User"
      ],
      "expected_enums": [],
      "expected_inspect": [
        "message User fields=6",
        "4 counters : repeated map<string, uint64>",
        "5 email : oneof contact string",
        "6 phone : oneof contact string"
      ],
      "official_features": [
        "scalar",
        "repeated",
        "map",
        "oneof"
      ],
      "expected_official_generated": [
        "pub struct User",
        "Map[String, UInt64]",
        "enum UserContact",
        "fn encode_json"
      ]
    },
    {
      "name": "decorated_telemetry",
      "proto": "examples/decorated/telemetry.proto",
      "expected_messages": [
        "Metadata",
        "TelemetryEvent"
      ],
      "expected_enums": [
        "Severity"
      ],
      "expected_inspect": [
        "package: moon.proto.lab.demo.v1",
        "message TelemetryEvent fields=7",
        "reserved numbers: 7, 9 to 12",
        "reserved names: old_payload",
        "enum Severity values=4",
        "reserved numbers: 9 to 12"
      ],
      "official_features": [
        "import",
        "option ignored by generator",
        "reserved",
        "enum",
        "optional",
        "map",
        "oneof"
      ],
      "expected_official_generated": [
        "pub enum Severity",
        "pub struct TelemetryEvent",
        "Option[String]",
        "Map[String, String]"
      ]
    },
    {
      "name": "scalar_matrix",
      "proto": "examples/official/scalar_matrix.proto",
      "expected_messages": [
        "ScalarMatrix"
      ],
      "expected_enums": [],
      "expected_inspect": [
        "message ScalarMatrix fields=17",
        "1 d : singular double",
        "2 f : singular float",
        "3 i32 : singular int32",
        "4 i64 : singular int64",
        "15 payload : singular bytes",
        "16 note : optional string",
        "17 samples : repeated uint32"
      ],
      "official_features": [
        "scalar",
        "float",
        "double",
        "int32",
        "int64",
        "uint32",
        "uint64",
        "fixed32",
        "fixed64",
        "bool",
        "string",
        "bytes",
        "optional",
        "repeated"
      ],
      "expected_official_generated": [
        "pub struct ScalarMatrix",
        "d : Double",
        "f : Float",
        "i32 : Int",
        "i64 : Int64",
        "u32 : UInt",
        "u64 : UInt64",
        "payload : Bytes",
        "note : Option[String]",
        "samples : Array[UInt]"
      ]
    }
  ]
}
